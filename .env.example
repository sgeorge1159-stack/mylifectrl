# Environment variables
# Copy this file to .env and fill in your values

OPENAI_API_KEY=sk-your-key-here
DATABASE_URL=./lifectrl.db
JWT_SECRET=change-this-to-a-random-secret-in-production
NODE_ENV=development
PORT=3001

# Stripe Integration
# Secret key from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks
# For local testing with Stripe CLI, use the whsec_*** key printed by `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
